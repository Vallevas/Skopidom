DATABASE_URL="postgres://skopidom:secret@localhost:5432/skopidom?sslmode=disable"

# Секрет должен быть минимум 32 символа.
JWT_SECRET=supersecretkey-change-in-prod-32ch
JWT_TTL="24h"

SERVER_PORT=8080

# True = подробные ошибки в ответах (только для разработки).
# False = только безопасные сообщения (прод).
DEBUG=True

# Домены через запятую: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

STORAGE_DIR="./uploads"
STORAGE_BASE_URL="http://localhost:8080/static"
MIGRATIONS_PATH=internal/infrastructure/postgres/migrations
